{
  "version": 2,
  "functions": {
    "api/search.py": { "maxDuration": 30 },
    "api/lyrics.py": { "maxDuration": 30 },
    "api/download.py": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/search", "dest": "/api/search.py" },
    { "src": "/api/lyrics", "dest": "/api/lyrics.py" },
    { "src": "/api/download", "dest": "/api/download.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|json|webmanifest|svg))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
